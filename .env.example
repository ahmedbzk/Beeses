# FTP Sunucu Bağlantı Bilgileri
# -----------------------------
# Sunucunuzun IP adresi veya FTP adresi (örn. ftp.beesesaudio.com veya 192.168.1.1)
FTP_HOST=

# FTP portu (Varsayılan olarak standart FTP için 21'dir)
FTP_PORT=21

# FTP kullanıcı adınız
FTP_USER=

# FTP şifreniz
FTP_PASSWORD=

# Sunucuda dosyaların yükleneceği hedef klasör (örn. /public_html veya /httpdocs)
FTP_REMOTE_PATH=/public_html

# Güvenli TLS bağlantısı (FTPS) kullanılıp kullanılmayacağı.
# Sunucunuz TLS/SSL destekliyorsa "true", aksi halde "false" yapın.
# Eğer sunucu TLS zorunlu kılmıyorsa "false" kalabilir.
FTP_SECURE=false
